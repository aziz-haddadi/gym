# Public deployment
GYM_HTTP_PORT=8013
GYM_PUBLIC_URL=https://gym.pulgaa.xyz
GYM_ALLOWED_HOSTS=gym.pulgaa.xyz,localhost,127.0.0.1
GYM_COOKIE_SECURE=true

# Initial account. The password itself lives in secrets/admin_password.txt.
GYM_ADMIN_USERNAME=pulgaa
GYM_ADMIN_TIMEZONE=Africa/Tunis

# Caddy authenticates the visitor and sends this header over the localhost-only hop.
GYM_TRUST_PROXY_AUTH=true
GYM_PROXY_AUTH_HEADER=X-Gym-User

# Database names/roles are not secrets. Passwords live under ./secrets.
GYM_DB_NAME=gym
GYM_DB_ADMIN_USER=gym_admin
GYM_DB_USER=gym_app
GYM_DB_HOST=db
GYM_DB_PORT=5432

# Runtime tuning
GYM_SESSION_DAYS=30
GYM_DB_POOL_SIZE=10
GYM_DB_MAX_OVERFLOW=20
GYM_LOG_LEVEL=INFO
